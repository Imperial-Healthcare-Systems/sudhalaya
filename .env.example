# Copy to .env.local and fill in from your Supabase project (Settings → API).
# When these are absent the app runs in offline/localStorage demo mode.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: create an owner admin login when running `node supabase/seed.mjs`
# SEED_ADMIN_EMAIL=owner@suddhalaya.com
# SEED_ADMIN_PASSWORD=change-me-strong
